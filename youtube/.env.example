# NAS/Media Path
MUSIC_ROOT=/path/to/nasmount/mainpath/downloads/music
SONGS_JSON_PATH=songs.json
STATE_DIR=./state

# Automation behavior
POLL_INTERVAL_SECONDS=60
RETRY_BACKOFF_SECONDS=5
MAX_ITEMS_PER_CYCLE=50

# YouTube Downloader (yt-dlp)
YT_SEARCH_MAX_RESULTS=5
YT_MATCH_MIN_SCORE=0.65
YT_OUTPUT_FORMAT=m4a
YT_AUDIO_QUALITY=0
YT_DOWNLOAD_ARCHIVE=true
# YT_COOKIES_FILE=/path/to/cookies.txt
# YT_PROXY=http://user:pass@host:port

# Archiving (move processed requests to another JSON)
FOUND_IN_LIBRARY_ARCHIVE_ENABLED=false
# FOUND_IN_LIBRARY_ARCHIVE_JSON_PATH=./state/found_in_library.json

# API Keys
# GENIUS_API_KEY=your_genius_api_key_here
# ACOUSTID_API_KEY=your_acoustid_api_key_here

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

POSTGRES_HOST=postgres
POSTGRES_PORT=5432